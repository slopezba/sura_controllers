  </class>

  <class
    name="sura_controllers/auv/BodyForceController"
    type="sura_controllers::common::BodyForceController"
    base_class_type="controller_interface::ChainableControllerInterface">
    <description>AUV body force controller</description>
  </class>

  <class
    name="sura_controllers/auv/BodyVelocityController"
    type="sura_controllers::auv::BodyVelocityController"
    base_class_type="controller_interface::ChainableControllerInterface">
